# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  JOKA — 環境變數完整清單                                                      ║
# ║  此檔案可 commit 到 Git，但「絕對不能」填入真實值。                               ║
# ║  真實值請放在 .env.local（已在 .gitignore 排除）                                ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── ① Supabase（Production + Preview 環境都要設定）───────────────────────────────
# 來源：Supabase 後台 → Settings → API

# Supabase 專案 URL（NEXT_PUBLIC_ = 前端可讀）
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Supabase anon key（NEXT_PUBLIC_ = 前端可讀，受 RLS 保護）
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase service role key（機密！server-only，絕不加 NEXT_PUBLIC_ 前綴）
# 外洩 = 任何人可繞過 RLS 讀寫所有資料
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key


# ── ② LINE Webhook（Production + Preview 環境都要設定）──────────────────────────
# 來源：LINE Developers Console → LINE Official Account → Messaging API

# LINE Webhook 簽名驗證 Channel Secret（機密，server-only）
LINE_CHANNEL_SECRET=your_line_channel_secret


# ── ③ JOKA 系統機密（Production + Preview 環境都要設定）────────────────────────
# 來源：自行產生強隨機字串

# Cron 保護 Secret，防止外部隨意觸發排程
# 產生方式：openssl rand -hex 32
CRON_SECRET=your_cron_secret_32_hex_chars

# JOKA 超管 Email，此帳號可登入 /admin 管理所有租戶
JOKA_ADMIN_EMAIL=admin@yourdomain.com


# ── ④ 網址設定（選填，有預設值 https://joka-app.vercel.app）──────────────────────

# 後台完整網址，用於 Email 邀請連結的 redirectTo
NEXT_PUBLIC_APP_URL=https://joka-app.vercel.app

# Site URL，用於超管「寄送密碼設定連結」的 redirectTo
NEXT_PUBLIC_SITE_URL=https://joka-app.vercel.app


# ── ⑤ LIFF Dev Mock（本機開發專用，Production/Preview 絕對不能設）───────────────
#
# 開啟後可在桌面瀏覽器直接測試 LIFF 頁面，跳過手機 LINE 登入。
# 操作步驟：
#   1. 在 Supabase 找一個測試會員的 line_uid：
#      SELECT line_uid, name FROM members WHERE tenant_id = 'your_tenant_id' LIMIT 5;
#   2. 把下面的值填到 .env.local（不要填到 .env！）
#   3. 重啟 dev server（npm run dev）
#
# NEXT_PUBLIC_LIFF_DEV=true
# NEXT_PUBLIC_LIFF_DEV_LINE_UID=U0123456789abcdef0123456789abcdef
# NEXT_PUBLIC_LIFF_DEV_NAME=測試王小明
# NEXT_PUBLIC_LIFF_DEV_PICTURE=
# LIFF_DEV=true


# ──────────────────────────────────────────────────────────────────────────────
# 以下設定「存在 Supabase DB（tenants table）」，不使用環境變數：
#   - LINE Channel Access Token（推播）→ tenants.channel_access_token
#   - LINE LIFF ID → tenants.liff_id
#   - LINE Login Channel ID → tenants.line_login_channel_id
#   - 集點/到期/生日等業務規則 → tenants table 各欄位
# ──────────────────────────────────────────────────────────────────────────────
